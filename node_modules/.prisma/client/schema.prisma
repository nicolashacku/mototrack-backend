generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Moto {
  id                      String   @id @default(cuid())
  marca                   String
  modelo                  String
  placa                   String   @unique
  anio                    Int
  kmActual                Int
  ultimoCambioAceiteKm    Int
  ultimoCambioAceiteFecha DateTime
  intervaloAceite         Int

  contrato       Contrato?
  mantenimientos MaintenanceLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Contrato {
  id           String   @id @default(cuid())
  cuotaDiaria  Int
  fechaInicio  DateTime
  arrendatario String
  dueno        String

  motoId String @unique
  moto   Moto   @relation(fields: [motoId], references: [id], onDelete: Cascade)

  pagos     Pago[]
  repuestos Repuesto[]
  users     User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Pago {
  id          String     @id @default(cuid())
  fecha       DateTime
  monto       Int
  semana      String
  estado      EstadoPago @default(PENDIENTE)
  comprobante String?

  contratoId String
  contrato   Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Repuesto {
  id        String    @id @default(cuid())
  fecha     DateTime
  nombre    String
  costo     Int
  pagadoPor PagadoPor
  categoria String
  imagen    String?

  contratoId String
  contrato   Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MaintenanceLog {
  id      String          @id @default(cuid())
  tipo    MaintenanceType
  fecha   DateTime
  km      Int
  detalle String?
  costo   Int?

  motoId String
  moto   Moto   @relation(fields: [motoId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id           String    @id @default(cuid())
  nombre       String
  email        String    @unique
  passwordHash String
  role         UserRole
  contratoId   String?
  contrato     Contrato? @relation(fields: [contratoId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum EstadoPago {
  VERIFICADO
  PENDIENTE
  RECHAZADO
}

enum PagadoPor {
  DUENO
  ARRENDATARIO
}

enum MaintenanceType {
  OIL_CHANGE
  KM_UPDATE
}

enum UserRole {
  OWNER
  TENANT
}
